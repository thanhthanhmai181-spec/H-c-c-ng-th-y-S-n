                                  {test.percentage}%
                                </div>
                                <div className={`w-full rounded-t-md transition-all duration-500 ${test.percentage >= 80 ? 'bg-green-400' : test.percentage >= 50 ? 'bg-yellow-400' : 'bg-red-400'}`} style={{ height: `${test.percentage}%`, minHeight: '4px' }}></div>
                              </div>
                            ))}
                          </div>
                        </div>

                      </div>
                    )}
                  </div>
                )}
              </main>

              {/* MODALS */}
              
              {/* Cửa sổ Luyện Viết */}
              {selectedWriteChar && (
                <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm animate-in fade-in duration-200" onClick={() => setSelectedWriteChar(null)}>
                  <div className="bg-white rounded-3xl shadow-2xl w-full max-w-sm overflow-hidden" onClick={e => e.stopPropagation()}>
                    <div className="flex items-center justify-between p-4 border-b border-slate-100">
                      <h3 className="text-lg font-bold text-slate-800 flex items-center gap-2">Tập viết chữ <span className="text-red-500 uppercase">{selectedWriteChar.r}</span></h3>
                      <button onClick={() => setSelectedWriteChar(null)} className="p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-full transition-colors"><i className="fas fa-times text-lg"></i></button>
                    </div>
                    <div className="p-6 text-center space-y-5 bg-slate-50">
                      <DrawingPad char={selectedWriteChar.char} />
                      <div className="flex flex-col items-center gap-3">
                        <button onClick={() => playAudio(selectedWriteChar.char)} className="flex items-center gap-2 px-6 py-2.5 bg-red-100 text-red-600 rounded-full font-semibold hover:bg-red-200 transition-colors text-sm shadow-sm">
                          <i className="fas fa-volume-up text-lg"></i> Nghe lại phát âm
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {/* Cửa sổ Xác nhận thoát bài Kiểm tra (Thay thế cho JS Confirm mặc định) */}
              {pendingTab && (
                <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm animate-in fade-in duration-200">
                  <div className="bg-white rounded-3xl shadow-2xl w-full max-w-sm overflow-hidden p-6 text-center">
                    <i className="fas fa-exclamation-triangle text-6xl text-yellow-500 mx-auto mb-4 block"></i>
                    <h3 className="text-xl font-bold text-slate-800 mb-2">Bạn có chắc chắn?</h3>
                    <p className="text-slate-500 mb-6">Bạn đang trong bài kiểm tra. Nếu thoát bây giờ, kết quả sẽ không được lưu lại.</p>
                    <div className="flex gap-3 justify-center">
                      <button onClick={() => setPendingTab(null)} className="px-6 py-2 rounded-full font-medium text-slate-600 bg-slate-100 hover:bg-slate-200 transition-colors">
                        Tiếp tục thi
                      </button>
                      <button onClick={confirmExitExam} className="px-6 py-2 rounded-full font-medium text-white bg-red-500 hover:bg-red-600 transition-colors shadow-md shadow-red-200">
                        Đồng ý thoát
                      </button>
                    </div>
                  </div>
                </div>
              )}
            </div>
          );
        }

        // Render application
        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
