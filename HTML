<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lớp Học Thầy Sơn - Nhật Ngữ Tương Tác</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;700&family=Quicksand:wght@300;400;600;700&family=Noto+Serif+JP:wght@400;700;900&family=Lora:ital,wght@0,400;0,700;1,400&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --jp-red: #BC002D;
            --jp-cream: #F9F7F2;
            --jp-ink: #2C3E50;
            --jp-grey: #7F8C8D;
            --jp-gold: #D4AF37;
            --game-glow: #FF6B35;
            --game-dark: #1A1A2E;
        }
        body {
            font-family: 'Quicksand', 'Noto Sans JP', sans-serif;
            background-color: var(--jp-cream);
            color: var(--jp-ink);
            scroll-behavior: smooth;
        }
        .japanese-pattern {
            background-image: url("https://www.transparenttextures.com/patterns/asfalt-light.png");
            background-color: var(--jp-cream);
        }
        .card-shadow {
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            transition: transform 0.3s ease;
        }
        .card-shadow:hover {
            transform: translateY(-5px);
        }
        .nav-active {
            border-bottom: 3px solid var(--jp-red);
            color: var(--jp-red);
        }

        /* Game & Knowledge styles */
        .washi-pattern {
            background-color: #FDFBF7;
            background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100' height='100' filter='url(%23noise)' opacity='0.05'/%3E%3C/svg%3E");
        }

        .card-antique {
            background-color: #fff;
            border: 2px solid #1A1A1A;
            box-shadow: 6px 6px 0px #1A1A1A;
            transition: all 0.3s ease;
        }

        .card-antique:hover {
            transform: translate(-4px, -4px);
            box-shadow: 10px 10px 0px #8B0000;
        }

        .card-locked {
            background-color: #f5f0eb;
            border: 2px dashed #999;
            box-shadow: 4px 4px 0px #ccc;
            opacity: 0.7;
            transition: all 0.3s ease;
        }

        .card-locked:hover {
            opacity: 0.85;
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px #bbb;
        }

        .hanko-seal {
            border: 2px solid #8B0000;
            color: #8B0000;
            border-radius: 4px;
            display: inline-block;
        }

        .tategaki {
            writing-mode: vertical-rl;
            text-orientation: upright;
            letter-spacing: 0.2em;
        }

        .game-card-active, .card-recommended {
            background: linear-gradient(145deg, #1a1a2e, #16213e);
            border: 2px solid var(--game-glow);
            box-shadow: 6px 6px 0px #1A1A1A, 0 0 30px rgba(255, 107, 53, 0.2);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .game-card-active::before, .card-recommended::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(45deg, transparent 60%, rgba(255, 107, 53, 0.05) 100%);
            pointer-events: none;
        }

        .game-card-active:hover, .card-recommended:hover {
            transform: translate(-4px, -4px);
            box-shadow: 10px 10px 0px #1A1A1A, 0 0 50px rgba(255, 107, 53, 0.4);
            border-color: #FF8C5A;
        }

        .game-title-glow, .knowledge-title-glow {
            text-shadow: 0 0 20px rgba(255, 107, 53, 0.5);
        }

        @keyframes pulse-glow {
            0%, 100% { box-shadow: 0 0 5px rgba(255, 107, 53, 0.3); }
            50% { box-shadow: 0 0 25px rgba(255, 107, 53, 0.6), 0 0 50px rgba(255, 107, 53, 0.2); }
        }

        .btn-play-now, .btn-read-more {
            animation: pulse-glow 2s infinite;
        }

        .tag-new, .tag-essential {
            background: var(--game-glow);
            color: white;
            font-weight: bold;
            font-size: 0.7rem;
            padding: 2px 8px;
            border-radius: 2px;
            letter-spacing: 0.1em;
        }

        .tag-dev, .tag-soon {
            background: #666;
            color: white;
            font-weight: bold;
            font-size: 0.7rem;
            padding: 2px 8px;
            border-radius: 2px;
            letter-spacing: 0.1em;
        }

        .tag-practical {
            background: #D4AF37;
            color: white;
            font-weight: bold;
            font-size: 0.7rem;
            padding: 2px 8px;
            border-radius: 2px;
            letter-spacing: 0.1em;
        }

        .games-grid, .knowledge-grid {
            display: grid;
            gap: 2rem;
            grid-template-columns: 1fr;
        }

        @media (min-width: 768px) {
            .games-grid, .knowledge-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (min-width: 1024px) {
            .games-grid, .knowledge-grid {
                grid-template-columns: repeat(3, 1fr);
            }
            .games-grid:has(> a:only-child), .games-grid:has(> div:only-child),
            .knowledge-grid:has(> a:only-child), .knowledge-grid:has(> div:only-child) {
                grid-template-columns: 1fr;
            }
            .games-grid>a:only-child, .games-grid>div:only-child,
            .knowledge-grid>a:only-child, .knowledge-grid>div:only-child {
                max-width: 500px;
                margin: 0 auto;
            }
            .games-grid:has(> a:nth-child(2):last-child), .games-grid:has(> div:nth-child(2):last-child),
            .knowledge-grid:has(> a:nth-child(2):last-child), .knowledge-grid:has(> div:nth-child(2):last-child) {
                grid-template-columns: repeat(2, 1fr);
                max-width: 800px;
                margin: 0 auto;
            }
            .games-grid:has(> a:nth-child(4):last-child),
            .knowledge-grid:has(> a:nth-child(4):last-child) {
                grid-template-columns: repeat(2, 1fr);
                max-width: 800px;
                margin: 0 auto;
            }
            .games-grid:has(> a:nth-child(5):last-child),
            .knowledge-grid:has(> a:nth-child(5):last-child) {
                grid-template-columns: repeat(6, 1fr);
                max-width: 100%;
            }
            .games-grid:has(> a:nth-child(5):last-child)>a,
            .knowledge-grid:has(> a:nth-child(5):last-child)>a {
                grid-column: span 2;
            }
            .games-grid:has(> a:nth-child(5):last-child)>a:nth-child(4),
            .knowledge-grid:has(> a:nth-child(5):last-child)>a:nth-child(4) {
                grid-column: 2 / span 2;
            }
            .games-grid:has(> a:nth-child(5):last-child)>a:nth-child(5),
            .knowledge-grid:has(> a:nth-child(5):last-child)>a:nth-child(5) {
                grid-column: 4 / span 2;
            }
        }
    </style>
</head>
